{
  "name": "@blask/monorepo",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/x0y14/blask.git"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' --stream run build",
    "release": "pnpm run build && pnpm -r --filter './packages/*' publish",
    "build:examples": "pnpm -r --filter './examples/**' --stream run build",
    "clean": "pnpm -r --filter './packages/*' --stream run clean",
    "clean:examples": "pnpm -r --filter './examples/**' --stream run clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt:check": "oxfmt .",
    "fmt": "oxfmt --write .",
    "typecheck": "pnpm -r --parallel --stream run typecheck",
    "test:e2e": "pnpm -r --stream run test:e2e"
  },
  "devDependencies": {
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
