---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AddToCart from "../../components/ec-add-to-cart.ts";
import type { Product } from "../../lib/types.js";

const { id } = Astro.params;
const res = await fetch(`http://localhost:3001/api/products/${id}`);
if (!res.ok) return Astro.redirect("/404");
const product: Product = await res.json();
---
<BaseLayout title={product.name}>
  <div class="mb-8">
    <a href="/" class="font-sans text-[10px] tracking-widest uppercase text-ink-faint hover:text-ink transition-colors">&larr; Back to collection</a>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
    <div class="bg-surface-warm aspect-4/5 overflow-hidden">
      <img src={product.image} alt={product.name} width="800" height="1000" class="w-full h-full object-cover" />
    </div>
    <div class="flex flex-col justify-center py-8 lg:py-16">
      <span class="font-sans text-[10px] tracking-widest uppercase text-ink-faint mb-4">{product.category}</span>
      <h1 class="font-display text-3xl lg:text-4xl font-300 tracking-tight text-ink leading-tight">{product.name}</h1>
      <p class="mt-4 font-display text-2xl font-300 text-ink">¥{product.price.toLocaleString("ja-JP")}</p>
      <p class="mt-8 font-sans text-sm leading-relaxed text-ink-muted">{product.description}</p>
      <p class="mt-3 font-sans text-[10px] tracking-widest uppercase text-ink-faint">在庫: {product.stock}点</p>
      <div class="mt-12 pt-8 border-t border-border">
        <AddToCart
          product-id={product.id}
          stock={product.stock}
          price={product.price}
          client:visible
        />
      </div>
    </div>
  </div>
  <script>import "../../components/ec-quantity-selector.js";</script>
</BaseLayout>
