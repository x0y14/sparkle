---
import CartProviderApp from "../components/ec-cart-provider-app.ts";
import CartBadge from "../components/ec-cart-badge.ts";

interface Props { title: string; }
const { title } = Astro.props;
---
<html lang="ja" style="scrollbar-gutter: stable">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | Sparkle EC</title>
</head>
<body class="bg-surface min-h-screen font-sans text-ink antialiased">
  <CartProviderApp client:load>
    <header class="bg-surface border-b border-border sticky top-0 z-50 backdrop-blur-sm bg-opacity-90">
      <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="font-display text-2xl font-300 tracking-tight text-ink hover:opacity-70 transition-opacity">Sparkle EC</a>
          <nav class="flex items-center">
            <CartBadge client:load />
          </nav>
        </div>
      </div>
    </header>
    <main class="max-w-7xl mx-auto px-6 lg:px-12 py-12 lg:py-16">
      <slot />
    </main>
    <footer class="border-t border-border mt-24">
      <div class="max-w-7xl mx-auto px-6 lg:px-12 py-12 flex items-center justify-between">
        <span class="font-display text-sm font-300 text-ink-faint">Sparkle EC</span>
        <span class="font-sans text-[10px] tracking-widest uppercase text-ink-faint">Sparkle</span>
      </div>
    </footer>
  </CartProviderApp>
</body>
</html>
