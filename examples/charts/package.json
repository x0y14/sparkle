{
  "name": "@examples/charts",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6007 --no-open",
    "build-storybook": "storybook build -o dist-storybook",
    "vrt:capture": "pnpm build-storybook && storycap --serverCmd 'npx http-server dist-storybook -p 6007 --silent' http://localhost:6007 -o __screenshots__/actual --parallel 2 --delay 1000 --viewport 800x600",
    "vrt:compare": "reg-cli __screenshots__/actual __screenshots__/expected __screenshots__/diff -R __screenshots__/report.html -J __screenshots__/report.json -T 0.01",
    "vrt:update": "rm -rf __screenshots__/expected && cp -r __screenshots__/actual __screenshots__/expected",
    "vrt": "pnpm vrt:capture && pnpm vrt:compare",
    "test:all": "pnpm test && pnpm typecheck && pnpm build && pnpm vrt"
  },
  "dependencies": {
    "@sparkio/astro": "workspace:*",
    "@sparkio/core": "workspace:*",
    "@sparkio/vite": "workspace:*",
    "@unocss/astro": "^66.0.0",
    "@unocss/reset": "^66.0.0",
    "astro": "^6.0.4",
    "unocss": "^66.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/html": "^10.0.0",
    "@storybook/html-vite": "^10.0.0",
    "@unocss/preset-wind4": "^66.6.6",
    "@webgpu/types": "^0.1.0",
    "happy-dom": "^20.0.0",
    "http-server": "^14.0.0",
    "puppeteer": "^23.0.0",
    "reg-cli": "^0.18.0",
    "storybook": "^10.0.0",
    "storycap": "^5.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.4.1",
    "vitest": "^4.0.0"
  }
}
