---
interface Props { title: string; }
const { title } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
</head>
<body class="bg-white min-h-screen antialiased">
  <slot />
</body>
</html>
